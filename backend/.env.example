# Copy to backend/.env and fill locally. Never commit backend/.env.
# Mode presets: docs/env_config_checklist.md

APP_NAME=AI Image Generator Backend

# development | production
# production: disables TEST_USER_ID fallback, /debug/*, mock-verify (404)
ENVIRONMENT=development

# mock = placeholder images (no Gemini cost) | gemini = real API (costs apply)
IMAGE_PROVIDER=mock

# Required for IMAGE_PROVIDER=gemini. Never commit real key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

FREE_GENERATIONS_LIMIT=3

# Supabase — placeholders only. Service role: backend only, never on client.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_STORAGE_BUCKET=generated-images

# Development only: fallback user when Flutter has no Bearer token.
# MUST be empty in production. Never use for real users in prod.
TEST_USER_ID=

# true = debit balance after successful generation (demo/production logic)
# false = safe mode — no balance debits (local dev / Gemini safe test)
ENABLE_CREDIT_CONSUMPTION=false

# true = POST /photoshoots/generate runs backend flow (mock or gemini)
# false = 501 placeholder response
ENABLE_PHOTOSHOOT_GENERATION=false

# 1–3 frames per photoshoot when generation enabled (default 3 for demo)
PHOTOSHOOT_OUTPUT_COUNT=3

# TODO(rustore): future server-side verification — not in config yet
# RUSTORE_API_KEY=
# RUSTORE_APP_ID=
