# Copy to backend/.env and fill locally. Never commit backend/.env.
# Mode presets: docs/env_config_checklist.md

APP_NAME=AI Image Generator Backend

# Semantic version returned by GET /health (no secrets).
APP_VERSION=0.1.0

# development | production
# production: disables TEST_USER_ID fallback, /debug/*, mock-verify (404)
ENVIRONMENT=development

# HTTP port (used by Docker CMD and local uvicorn; default 8000)
PORT=8000

# mock = placeholder images (no Gemini cost) | gemini = real API (costs apply)
# Fallback when TEMPLATE_IMAGE_PROVIDER / PHOTOSHOOT_IMAGE_PROVIDER are unset.
IMAGE_PROVIDER=mock

# Optional per-flow overrides (unset = use IMAGE_PROVIDER).
# Values: mock | gemini | kie_gpt_image_2
TEMPLATE_IMAGE_PROVIDER=
PHOTOSHOOT_IMAGE_PROVIDER=

# Required for IMAGE_PROVIDER=gemini. Never commit real key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

# Kie API (gpt-image-2-image-to-image). Required when provider is kie_gpt_image_2.
KIE_API_KEY=
KIE_API_BASE_URL=https://api.kie.ai
KIE_IMAGE_MODEL=gpt-image-2-image-to-image
KIE_IMAGE_RESOLUTION=2K
KIE_IMAGE_ASPECT_RATIO=3:4
KIE_TASK_TIMEOUT_SECONDS=300
KIE_POLL_INITIAL_DELAY_SECONDS=2
KIE_POLL_MAX_DELAY_SECONDS=8
KIE_TEMP_SIGNED_URL_TTL_SECONDS=3600
KIE_MAX_PHOTOSHOOT_TASKS=5
KIE_CREATE_TASK_RATE_LIMIT=15
KIE_CREATE_TASK_RATE_WINDOW_SECONDS=10

FREE_GENERATIONS_LIMIT=3

# Free generations apply to single-photo flows only (template / custom idea).
# Photoshoots always require paid_image_generations (3 images per session).

# Supabase — placeholders only. Service role: backend only, never on client.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_STORAGE_BUCKET=generated-images
# Private bucket for temporary Kie input signed URLs (not public).
SUPABASE_TEMP_STORAGE_BUCKET=ai-temp-inputs

# Development only: fallback user when Flutter has no Bearer token.
# MUST be empty in production. Never use for real users in prod.
TEST_USER_ID=

# true = debit balance after successful generation (set for production)
# false = safe mode — no balance debits (local dev / Gemini safe test)
ENABLE_CREDIT_CONSUMPTION=false

# true = POST /payments/mock/photo-pack credits photo packs without real payment
# Allowed when ENVIRONMENT != production, or explicitly enabled on staging.
ENABLE_MOCK_PAYMENTS=false

# true = POST /photoshoots/generate runs backend flow (mock or gemini)
# false = 501 placeholder response
ENABLE_PHOTOSHOOT_GENERATION=false

# 1–3 frames per photoshoot when generation enabled (default 3 for demo)
PHOTOSHOOT_OUTPUT_COUNT=3

# Gemini photoshoot series reference strategy (default in code: identity_anchor)
# identity_anchor = recommended — frame 0 uses original photo; frames 1/2 use original + first generated frame
# legacy = old behavior — every frame uses original photo only
# anchor_only = frames 1/2 use first generated frame only (fallback / manual test)
PHOTOSHOOT_SERIES_REFERENCE_MODE=identity_anchor

# CORS — comma-separated trusted origins for browser clients (Flutter web, admin).
# Development: leave empty → allow all origins (*).
# Production: set explicit HTTPS origins, e.g. https://app.example.com
ALLOWED_ORIGINS=

# TODO(rustore): future server-side verification — not in config yet
# RUSTORE_API_KEY=
# RUSTORE_APP_ID=
